---
layout: base.njk
pagination:
  data: collections.publicTags
  size: 1
  alias: tag
permalink: /tags/{{ tag | tagSlug }}/
eleventyComputed:
  title: "FileZilla {{ tag }} 内容合集"
  description: "FileZilla {{ tag }} 相关文章合集。"
---
<section class="section">
  <div class="container">
    <header class="section-head">
      <p class="kicker">Tags</p>
      <h1>FileZilla {{ tag }} 内容合集</h1>
    </header>
    <div class="list-grid">
      {% for post in collections.posts %}
        {% if post.data.tags and tag in post.data.tags %}
          <article class="list-card">
            {% if post.data.heroImage %}
              <a href="{{ post.url }}">
                <img src="{{ post.data.heroImage }}" alt="{{ post.data.heroAlt or post.data.title }}" loading="lazy">
              </a>
            {% endif %}
            <time datetime="{{ post.date | readableDate }}">{{ post.date | readableDate }}</time>
            <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
            <p>{{ post.data.description }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
