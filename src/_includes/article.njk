---
layout: base.njk
---
<div class="container page-layout">
  <article class="article-main">
    <p class="kicker">{{ category or "传输资料" }}</p>
    <h1>{{ title }}</h1>
    <p class="meta-line">{{ page.date | readableDate }} · FileZilla</p>
    {% if heroImage %}
      <img class="hero-img" src="{{ heroImage }}" alt="{{ heroAlt or title }}" loading="lazy">
    {% endif %}
    {{ content | safe }}
    {% if videoTitle %}
      <section class="video-block" aria-labelledby="video-heading">
        <h2 id="video-heading">{{ videoTitle }}</h2>
        <p>{{ videoDescription }}</p>
        <div class="video-shell video-poster" data-video-lazy="{{ videoLazy | default('') }}">
          <img src="{{ videoPoster }}" alt="{{ videoTitle }} 安装演示画面" loading="lazy">
          <span>视频安装教程</span>
        </div>
        {% if videoPoster %}
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "VideoObject",
          "name": "{{ videoTitle }}",
          "description": "{{ videoDescription }}",
          "thumbnailUrl": "{{ videoPoster }}",
          "uploadDate": "{{ page.date | readableDate }}"
        }
        </script>
        {% endif %}
      </section>
    {% endif %}
  </article>
  <aside class="article-aside">
    <h2>相关入口</h2>
    <a href="/dows.html">客户端下载</a>
    <a href="/blog/">全部文章</a>
    <a href="/categories/">目录</a>
    <a href="/tags/">Tags</a>
    {% if category %}
      <a href="/categories/{{ category | categorySlug }}/">{{ category }}</a>
    {% endif %}
    {% set cleanTags = tags | publicTags %}
    {% if cleanTags.length %}
      <h2>Tags</h2>
      <div class="chip-row">
        {% for tag in cleanTags %}
          <a href="/tags/{{ tag | tagSlug }}/">{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}
  </aside>
</div>
