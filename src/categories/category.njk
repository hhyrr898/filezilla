---
layout: base.njk
pagination:
  data: collections.publicCategories
  size: 1
  alias: category
permalink: /categories/{{ category | categorySlug }}/
eleventyComputed:
  title: "FileZilla {{ category }} 专题"
  description: "FileZilla {{ category }} 相关文章与教程合集。"
---
<section class="section">
  <div class="container">
    <header class="section-head">
      <p class="kicker">目录</p>
      <h1>FileZilla {{ category }} 专题</h1>
    </header>
    <div class="list-grid">
      {% for post in collections.posts %}
        {% if post.data.category == category %}
          <article class="list-card">
            {% if post.data.heroImage %}
              <a href="{{ post.url }}">
                <img src="{{ post.data.heroImage }}" alt="{{ post.data.heroAlt or post.data.title }}" loading="lazy">
              </a>
            {% endif %}
            <time datetime="{{ post.date | readableDate }}">{{ post.date | readableDate }}</time>
            <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
            <p>{{ post.data.description }}</p>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
