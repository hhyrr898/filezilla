---
layout: base.njk
---
<div class="container page-layout">
  <article class="article-main">
    <p class="kicker">{{ category or "传输资料" }}</p>
    <h1>{{ title }}</h1>
    <p class="meta-line">{{ page.date | readableDate }}{% if updated %} · 更新于 {{ updated | readableDate }}{% endif %} · FileZilla</p>
    {% if heroImage %}
      <img class="hero-img" src="{{ heroImage }}" alt="{{ heroAlt or title }}" loading="lazy">
    {% endif %}
    {{ content | safe }}
    {% if videoTitle %}
      <section class="video-block" aria-labelledby="video-heading">
        <h2 id="video-heading">{{ videoTitle }}</h2>
        <p>{{ videoDescription }}</p>
        <div class="video-shell video-poster" data-video-lazy="{{ videoLazy | default('') }}">
          <img src="{{ videoPoster }}" alt="{{ videoTitle }} 安装演示画面" loading="lazy">
          <span>视频安装教程</span>
        </div>
        {% if videoPoster %}
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "VideoObject",
          "name": "{{ videoTitle }}",
          "description": "{{ videoDescription }}",
          "thumbnailUrl": "{{ videoPoster }}",
          "uploadDate": "{{ page.date | readableDate }}"
        }
        </script>
        {% endif %}
      </section>
    {% endif %}
  </article>
  <aside class="article-aside">
    <h2>相关入口</h2>
    <a href="/dows.html">客户端下载</a>
    <a href="/blog/">全部文章</a>
    <a href="/categories/">目录</a>
    <a href="/tags/">Tags</a>
    {% if category %}
      <a href="/categories/{{ category | categorySlug }}/">{{ category }}</a>
    {% endif %}
    {% set cleanTags = tags | publicTags %}
    {% if cleanTags.length %}
      <h2>Tags</h2>
      <div class="chip-row">
        {% for tag in cleanTags %}
          <a href="/tags/{{ tag | tagSlug }}/">{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}
  </aside>
</div>

<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": page.date | readableDate,
  "dateModified": updated or (page.date | readableDate),
  "author": {
    "@type": "Organization",
    "name": site.author
  },
  "publisher": {
    "@type": "Organization",
    "name": site.name,
    "url": site.url
  },
  "mainEntityOfPage": site.url + page.url
} | dump | safe }}
</script>
<script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "首页",
      "item": site.url + "/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "博客",
      "item": site.url + "/blog/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": site.url + page.url
    }
  ]
} | dump | safe }}
</script>
