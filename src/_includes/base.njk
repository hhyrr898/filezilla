<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% set docTitle = title or site.title %}
    {% set metaDescription = description or site.description %}
    {% set canonical = site.url + (canonicalUrl or page.url or "/") %}
    <title>{% if docTitle != site.title %}{{ docTitle }} | FileZilla{% else %}{{ site.title }}{% endif %}</title>
    <meta name="description" content="{{ metaDescription }}">
    {% if noindex %}
    <meta name="robots" content="noindex,follow">
    {% else %}
    <meta name="robots" content="index,follow,max-image-preview:large">
    {% endif %}
    <link rel="canonical" href="{{ canonical }}">
    <meta property="og:type" content="{% if layout == 'article.njk' %}article{% else %}website{% endif %}">
    <meta property="og:title" content="{{ docTitle }}">
    <meta property="og:description" content="{{ metaDescription }}">
    <meta property="og:url" content="{{ canonical }}">
    <meta property="og:site_name" content="{{ site.name }}">
    <meta property="og:locale" content="zh_CN">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="stylesheet" href="/assets/styles.css">
    <script type="application/ld+json">
{{ {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": site.name,
  "url": site.url,
  "description": site.description
} | dump | safe }}
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-row">
        <a class="brand" href="/" aria-label="FileZilla">
          <img src="/assets/logo.svg" alt="FileZilla 标识" width="44" height="44">
          <span class="brand-text">FileZilla</span>
        </a>
        <nav class="nav" aria-label="主导航">
          <a href="/">首页</a>
          <a href="/dows.html">下载中心</a>
          <a href="/blog/">博客</a>
        </nav>
      </div>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer class="site-footer">
      <div class="container footer-wrap">
        <section>
          <h2>FileZilla FTP</h2>
          <p>FileZilla FTP 与 SFTP 连接、站点管理、文件传输与服务器日常维护内容，帮助开发与运维人员更快上手。</p>
        </section>
        <nav aria-label="页脚导航">
          <a href="/">FileZilla 客户端</a>
          <a href="/dows.html">客户端下载</a>
          <a href="/blog/">技术文章</a>
          <a href="/categories/">目录</a>
          <a href="/tags/">Tags</a>
          <a href="/sitemap.xml">站点地图</a>
        </nav>
      </div>
    </footer>
    <script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js" defer></script>
    <script>window.addEventListener("load",function(){if(window.LA){LA.init({id:"3K7l95Zodr0uFrIN",ck:"3K7l95Zodr0uFrIN"})}})</script>
  </body>
</html>
